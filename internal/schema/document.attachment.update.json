{
  "method": "PATCH",
  "path": "/multiapi/v1/attachments/{docid}/{attach_seq}",
  "summary": "添付ファイル更新",
  "description": "指定された添付ファイルを更新する。multipart/form-data。更新権限が必要。\n`delete=true` を指定するとファイル削除として動作する (xp document attachment delete で利用)。\n",
  "parameters": [
    {
      "name": "docid",
      "in": "path",
      "type": "integer",
      "required": true,
      "description": "書類ID"
    },
    {
      "name": "attach_seq",
      "in": "path",
      "type": "integer",
      "required": true,
      "description": "添付番号"
    }
  ],
  "requestBody": {
    "contentType": "multipart/form-data",
    "description": "添付ファイル更新/削除リクエスト。required: user_code。\n",
    "properties": {
      "user_code": {
        "type": "string",
        "required": true,
        "description": "ユーザコード"
      },
      "delete": {
        "type": "boolean",
        "description": "true: 削除 / false: 更新 (既定 false)"
      },
      "file": {
        "type": "string",
        "format": "binary",
        "description": "アップロードファイル情報 (備考のみ更新したい場合は指定不要)"
      },
      "file_name": {
        "type": "string",
        "description": "アップロードファイル名 (file を指定する場合は必須)"
      },
      "remarks": {
        "type": "string",
        "description": "備考"
      },
      "reason": {
        "type": "string",
        "description": "更新/削除理由 (電帳法データ保存対象フォームでは必須)"
      },
      "detail_no": {
        "type": "integer",
        "description": "対応明細行No (電帳法添付型フォーム用)"
      },
      "evidence_type": {
        "type": "integer",
        "description": "電帳法書類区分 (0: その他 / 1: 電子取引)"
      }
    }
  },
  "response": {
    "type": "object",
    "properties": {
      "docid": {
        "type": "integer",
        "description": "書類ID"
      },
      "seq": {
        "type": "integer",
        "description": "添付番号"
      },
      "message_type": {
        "type": "integer",
        "description": "メッセージタイプ (0: NoError 固定)"
      },
      "message": {
        "type": "string",
        "description": "メッセージ内容"
      },
      "detail": {
        "type": "string",
        "description": "指定 user_code が未登録の場合のフォールバック通知"
      }
    }
  }
}
